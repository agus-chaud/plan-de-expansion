# Base de datos REDATAM (binarios, 400MB+)
01_datos_raw/censo_2022/redatam_exports/Base_VP/

# CSV exportados de RedatamX (se regeneran ejecutando los .rpf)
01_datos_raw/censo_2022/redatam_exports/csv_output/

# Shapefile nacional completo (67MB, duplicado innecesario)
01_datos_raw/cartografia/MGN_2022_radios/radios_censales_MGN2022.zip

# Shapefile de provincias (granularidad provincial, no útil para el análisis)
01_datos_raw/cartografia/MGN_2022_radios/pxpciadatosok.*

# ZIP duplicado (ya está extraído como pxpciadatosok.shp)
01_datos_raw/cartografia/MGN_2022_radios/Codgeo_Pais_x_prov_datos.zip

